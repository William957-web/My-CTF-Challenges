'''
=Point(x=208575004931034605670207776382890912999778286373596592720314285399357519653410914021514415476064539486957273678872344235502557267036732653849917068621458424, y=1456861247614489372217629808546675465409295807381982024352711868200542968822309826522945466459372208332398838471137819520611154597984018940347432707518687762)
42e84344bf0779880563db428e900c6672537728fadedaadef5dddec765037af
'''

CNT_coords = (458147957015177490918637746428704145014841455781065073691030538199399565821048269670954744516211034948673479835934705967812288559302221491874168732555871673, 1108161610439720222909748658983441750265789100636627932923108298637841449759177130268809294451108250289946332015632800751192832850682586935208488629608531046)
enc_hex = "6dce2d805d79c6c3aa10baa269e30595dafd1aa4151c4c4e8f09c81f6ecd1886f62a1d17cb6f9e15707182b4de357b462e0b0152941f5db277714360a280ad53"

# --- 1. 分析奇點 ---
print("[*] 正在計算奇點參數...")
x0 = ZZ(-3 * b_curve * pow(2 * a_curve, -1, p) % p)
# Node 的映射參數 omega^2 = f''(x0)/2 = 3*x0
omega2 = (3 * x0) % p

if kronecker(omega2, p) == -1:
    print("[+] omega^2 不是平方剩餘，映射到 GF(p^2) 的單位範數子群 (階數 p+1)")
    K_ext.<i> = GF(p^2, modulus=x^2 - omega2)
    omega = i
    order = p + 1
else:
    print("[+] omega^2 是平方剩餘，映射到 GF(p)^* (階數 p-1)")
    omega = sqrt(GF(p)(omega2))
    K_ext = GF(p)
    order = p - 1

def phi(P):
    x_val, y_val = K_ext(P[0]), K_ext(P[1])
    return (y_val + omega*(x_val - x0)) / (y_val - omega*(x_val - x0))

# --- 2. 解 DLP ---
print("[*] 正在計算映射值與離散對數...")
target_val = phi(CNT_coords)
from tqdm import tqdm
base_vals = [phi(c) for c in tqdm(cs_coords)]

print("[*] 正在構造子群生成元 (不使用 .order()，避免卡死)...")



# 1. 在 GF(p^2) 隨機選一個元素

alpha = K_ext.random_element()



# 2. 利用 Frobenius Automorphism 把元素投影到階數為 p+1 的子群

# 原理：在 GF(p^2) 中，x^(p-1) 的階數一定是 p+1 的因數

g = alpha^(p-1) 



# 如果運氣太差拿到 1，就換一個 (機率極低)

while g == 1:

    alpha = K_ext.random_element()

    g = alpha^(p-1)

T_log = pari.fflog(target_val, g, order)
L_logs = [pari.fflog(b, g, order) for b in tqdm(base_vals)]
print(T_log)
print(L_logs)

# --- 3. LLL 恢復 Seed ---
# --- 3. LLL 恢復 Seed (修正版) ---
print("[*] 正在構造格點矩陣還原種子...")

# 確保所有數據都是 Sage 整數
M = ZZ(lcg_M)
T_log = ZZ(T_log)
L_logs = [ZZ(x) for x in L_logs]

# LCG 係數預計算
A_list = [pow(lcg_a, i, M) for i in range(17)]
B_list = [0] * 17
for i in range(1, 17):
    B_list[i] = (lcg_a * B_list[i-1] + lcg_b) % M

# 建立方程: s0 * coeff_s0 - sum(r_i * L_i) = const_val (mod M)
coeff_s0 = sum(A_list[i+1] * L_logs[i] for i in range(15)) % M
const_val = (2**16 * T_log - sum(B_list[i+1] * L_logs[i] for i in range(15))) % M

# 構造矩陣
# 目標向量: (k, s0, r_1, ..., r_15, 1) 其中 k 是使得方程成立的整數
n = 15
dim = n + 2 # s0 + r_1...r_15 + target
matrix = Matrix(ZZ, dim + 1, dim + 1)

# 設定平衡權重
# 我們希望 s0 * W_s0, r_i * W_r, 1 * W_target 的量級接近
# s0 ~ 2^128, r_i ~ 2^16, Target = 1
X = 2**128 
W_s0 = 1
W_r = 2**(128 - 16)  # 2^112, 補償 r_i 的小範圍
W_target = 2**128
W_eq = 2**512        # 強制讓第一列（方程餘數）歸零

# 填充矩陣列
# Row 0: 處理 s0
matrix[0, 0] = coeff_s0
matrix[0, 1] = W_s0

# Rows 1-15: 處理 r_i
for i in range(n):
    matrix[i+1, 0] = (-L_logs[i]) % M
    matrix[i+1, i+2] = W_r

# Row 16: 處理模數 M (k*M)
matrix[n+1, 0] = M

# Row 17: 處理常數項 (Target Embedding)
matrix[n+2, 0] = -const_val
matrix[n+2, n+2] = W_target

print("[*] 執行高維 LLL 縮減 (約需數秒)...")
res = matrix.LLL()



# 4. 提取 Seed 並解密
found = False
for row in res:
    # 檢查 Target 位是否為 +/- W_target
    if abs(row[n+2]) == W_target:
        # 根據權重還原 s0
        s0_recovered = abs(row[1]) // W_s0
        
        # 驗證 seed (s0 必須小於 M 且符合邏輯範圍)
        if s0_recovered == 0 or s0_recovered >= M:
            continue
            
        print(f"[+] 找到候選種子: {s0_recovered}")
        
        # 模擬 PRNG 狀態演進
        curr = s0_recovered
        # 15 次 next() 用於 CNT
        for _ in range(15):
            curr = (lcg_a * curr + lcg_b) % M
        # 第 16 次 next() 用於 AES Key
        curr = (lcg_a * curr + lcg_b) % M
        v16 = curr >> 16
        
        # AES 解密
        key = sha256(str(v16).encode()).digest()[:16]
        cipher = AES.new(key, AES.MODE_ECB)
        try:
            flag_raw = cipher.decrypt(bytes.fromhex(enc_hex))
            # 移除 Padding 並檢查格式
            if b"TSCCTF" in flag_raw:
                print(f"\n[!] 成功解密！")
                print(f"[!] FLAG: {unpad(flag_raw, 16).decode()}")
                found = True
                break
        except Exception as e:
            continue

if not found:
    print("[-] 遺憾，LLL 未能找到正確種子。請檢查 CNT 或加密數據是否輸入完整。")